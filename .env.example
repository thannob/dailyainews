# Daily AI News — environment variables
#
# The skill resolves env through a 3-tier order (see SKILL.md Step 0):
#   1. Cloud Environment of the Routine (preferred)
#   2. Inline in the skill invocation prompt
#   3. reference/defaults.json (NON-SECRETS ONLY: GITHUB_*)
#
# This file itself is NOT read by the skill — it's a cheat sheet for what
# to paste into the Routine's Cloud Environment panel.
#
# Never commit a real .env — see .gitignore.

# --- GitHub target (required) ---------------------------------------------
# Where the daily brief gets committed.
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=dailyainews
GITHUB_BRANCH=main

# --- LINE Messaging API (optional) ----------------------------------------
# If both are set, the skill posts a TL;DR after the commit.
# If either is missing, the LINE step is skipped cleanly (commit still runs).
#
# Channel access token from LINE Developers console:
#   https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=

# Target userId / groupId / roomId for the push message.
# For a 1:1 bot this is the userId from the webhook payload.
LINE_TO=
