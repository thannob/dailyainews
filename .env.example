# Daily AI News — environment variables
#
# Two surfaces, two purposes:
#
#   A. The skill (runs in the Routine) reads GITHUB_* from either an
#      inline prompt paste or from .claude/skills/daily-ai-news/reference/
#      defaults.json. This file is a cheat sheet — not read by anything.
#
#   B. The GitHub Actions workflow (.github/workflows/line-notify.yml)
#      reads LINE_* from GitHub repo secrets:
#        Repo -> Settings -> Secrets and variables -> Actions
#      The workflow is where LINE_* actually need to live — do NOT put
#      them in the Routine prompt or anywhere in the repo.
#
# Never commit a real .env — see .gitignore.

# --- A. GitHub target (used by the skill) ---------------------------------
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=dailyainews
GITHUB_BRANCH=main

# --- B. LINE Messaging API (used by GH Actions, NOT by the skill) --------
# Channel access token from LINE Developers console:
#   https://developers.line.biz/console/
# Set as a GitHub repo secret named LINE_CHANNEL_ACCESS_TOKEN.
LINE_CHANNEL_ACCESS_TOKEN=

# Target userId (U...), groupId (C...), or roomId (R...).
# Set as a GitHub repo secret named LINE_TO.
LINE_TO=
